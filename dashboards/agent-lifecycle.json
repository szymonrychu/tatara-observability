    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Terminal Task outcomes (operator_task_terminal_total) broken down by kind, phase (Succeeded/Failed) and reason. Cumulative counts since the operator last restarted. Filter with the Kind variable. This is the phase/reason count breakdown, distinct from the token-cost operator_task_terminal_tokens_total series on the Task Delivery dashboard.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "phase"},
            "properties": [
              {"id": "custom.width", "value": 110},
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "Failed": {"color": "red", "index": 1, "text": "Failed"},
                      "Succeeded": {"color": "green", "index": 0, "text": "Succeeded"}
                    },
                    "type": "value"
                  }
                ]
              },
              {"id": "custom.cellOptions", "value": {"type": "color-background"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "kind"},
            "properties": [{"id": "custom.width", "value": 150}]
          },
          {
            "matcher": {"id": "byName", "options": "Count"},
            "properties": [
              {"id": "unit", "value": "short"},
              {"id": "custom.width", "value": 90},
              {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 30},
      "id": 8,
      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": ["Count"], "reducer": ["sum"], "show": true},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "Count"}]
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "sum by (kind, phase, reason) (operator_task_terminal_total{kind=~\"$kind\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "title": "Terminal Task Outcomes",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "container": true,
              "endpoint": true,
              "instance": true,
              "job": true,
              "namespace": true,
              "pod": true,
              "service": true
            },
            "includeByName": {},
            "indexByName": {"kind": 0, "phase": 1, "reason": 2},
            "renameByName": {"Value": "Count"}
          }
        }
      ],
      "type": "table"
    },
