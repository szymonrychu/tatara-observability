        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "sum by (from, to) (rate(tatara_lifecycle_transition_total[5m]))",
          "legendFormat": "{{from}} to {{to}}",
          "refId": "A"
        }
      ],
      "title": "Lifecycle Transition Rate (from to)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
