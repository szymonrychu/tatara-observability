  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Current task count in each issueLifecycle state (tatara_lifecycle_state). Fleet-wide: the operator emits this with no project label. The state enum is dynamic (Triage, Conversation, Implement, MRCI, MainCI, Merge, Deploying, Done, Parked, Stopped); the terminal buckets Stopped and Parked normally dominate by orders of magnitude, so each state is shown as its own stat tile rather than a shared axis.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "min": 0,
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showPercentChange": false,
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "sum by (state) (tatara_lifecycle_state)",
          "instant": true,
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "title": "Current Tasks per Lifecycle State",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
