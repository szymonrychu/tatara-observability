        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "sum by (state) (tatara_lifecycle_state{state!~\"Stopped|Parked|Done\"})",
          "legendFormat": "{{state}}",
