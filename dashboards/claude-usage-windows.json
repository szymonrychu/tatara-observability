  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Claude account usage utilization (0-100%) per window (five_hour, seven_day, seven_day_opus, seven_day_sonnet), from the operator's usage-window poller (tatara_account_usage_utilization, tatara-operator internal/obs/operator_metrics.go). Sustained high utilization on a window means the shared account is close to that window's ceiling.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "off"}
          },
          "mappings": [],
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 95}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "legend": {"calcs": ["mean", "lastNotNull"], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "tatara_account_usage_utilization",
          "legendFormat": "{{window}}",
          "refId": "A"
        }
      ],
      "title": "Account Usage Utilization by Window",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Current utilization snapshot per window. One gauge bar per window (five_hour, seven_day, seven_day_opus, seven_day_sonnet). Thresholds mark the proactive-warning (70%) and near-ceiling (95%) bands.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 95}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "id": 2,
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "tatara_account_usage_utilization",
          "instant": true,
          "legendFormat": "{{window}}",
          "refId": "A"
        }
      ],
      "title": "Current Utilization by Window",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Time remaining until each usage window resets, derived from tatara_account_usage_resets_at_seconds (unix seconds) minus the current time. A negative or missing value means the window has no active reset countdown (e.g. never polled successfully yet).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 8},
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "tatara_account_usage_resets_at_seconds - time()",
          "instant": true,
          "legendFormat": "{{window}}",
          "refId": "A"
        }
      ],
      "title": "Reset Countdown by Window",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "1 when the account-usage poller's last cycle succeeded, 0 when stale (poll failures exceeded the failure threshold - tatara_account_usage_poll_health, tatara-operator internal/accountusage/poller.go). Stale means the gate keeps holding on the last-known windows until they expire (eventual fail-open, by design); the ladder is no longer refreshed on live account data.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"0": {"color": "red", "text": "STALE"}, "1": {"color": "green", "text": "healthy"}}, "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 4, "x": 8, "y": 8},
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "tatara_account_usage_poll_health",
          "instant": true,
          "legendFormat": "poll health",
          "refId": "A"
        }
      ],
      "title": "Usage Poll Health",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Monthly pay-as-you-go overage: read-only, never gates spawning (design non-goal). Percent utilization, amount used, and the plan limit (tatara_account_overage_percent/used/limit).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 100}
            ]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byFrameRefID", "options": "A"},
            "properties": [
              {"id": "unit", "value": "percent"},
              {"id": "displayName", "value": "Overage %"}
            ]
          },
          {
            "matcher": {"id": "byFrameRefID", "options": "B"},
            "properties": [
              {"id": "unit", "value": "currencyUSD"},
              {"id": "displayName", "value": "Overage Used"}
            ]
          },
          {
            "matcher": {"id": "byFrameRefID", "options": "C"},
            "properties": [
              {"id": "unit", "value": "currencyUSD"},
              {"id": "displayName", "value": "Overage Limit"}
            ]
          }
        ]
