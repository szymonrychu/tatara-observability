      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "sum by (project, kind) (rate(operator_admission_blocked_total{reason=\"kind_ceiling\"}[15m]))",
