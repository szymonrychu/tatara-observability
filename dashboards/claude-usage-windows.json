          "legendFormat": "Overage Limit",
          "refId": "C"
        }
      ],
      "title": "Monthly Overage (read-only)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Per-kind admission holds attributed to the account-usage kind ceiling (operator_admission_blocked_total{reason=\"kind_ceiling\"}, tatara-operator internal/obs/operator_metrics.go). A non-zero rate for a kind means that Task kind is CURRENTLY being held back by its spawnCeilingByKind threshold in claudeSubscription mode.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
