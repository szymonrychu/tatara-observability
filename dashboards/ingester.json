  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Fraction of ingest runs succeeding over a rolling 1h, from ingest_run_result_total{result=success|failure} (tatara-memory-repo-ingester, re-exported by the operator pushmetrics receiver as job=tatara-operator / exported_job=tatara-ingest). These are push-once counters held at a constant value until TTL-evicted, so rate()/increase() read 0 and an instant last-value query is empty between runs - max_over_time([1h]) is the correct windowed aggregation. Below 0.5 for 15m is what the tatara-ingester.yaml run-failure-ratio alert pages on.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "green", "value": 0.9}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "sum(max_over_time(ingest_run_result_total{result=\"success\"}[1h])) / clamp_min(sum(max_over_time(ingest_run_result_total[1h])), 1) or vector(0)",
          "instant": false,
          "legendFormat": "success ratio",
          "refId": "A"
        }
      ],
      "title": "Run Success Ratio (rolling 1h)",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Ingest runs seen over a rolling 1h split by outcome, from ingest_run_result_total{result=success|failure}. Push-once counters: max_over_time([1h]) counts each distinct run_id series present in the window (rate()/increase() read 0). An incremental run doing less than a full run is not a failure - failure means a genuinely failed run.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 60,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "normal"},
            "thresholdsStyle": {"mode": "off"}
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "failure"},
            "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]
          },
          {
            "matcher": {"id": "byName", "options": "success"},
            "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 18, "x": 6, "y": 0},
      "id": 2,
      "options": {
        "legend": {"calcs": ["max", "lastNotNull"], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "sum by (result) (max_over_time(ingest_run_result_total[1h]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "title": "Ingest Runs by Result (rolling 1h)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "p95 duration per ingest stage from ingest_stage_duration_seconds_bucket{stage} (live stages: push_chunks, push_graph, total). Buckets are push-once/held, so histogram_quantile is computed over max_over_time([1h]) of the cumulative bucket counts (rate() reads 0 and yields NaN). p95 pinned at the top finite bucket (10s) means the real p95 exceeds the 10s bucket boundary. Idle windows render as gaps - an idle ingester is not a slow one (CONVENTIONS.md).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 6,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "off"}
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "options": {
        "legend": {"calcs": ["max", "lastNotNull"], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (stage, le) (max_over_time(ingest_stage_duration_seconds_bucket[1h])))",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ],
      "title": "Per-Stage Duration p95 (rolling 1h)",
      "type": "timeseries"
    },
