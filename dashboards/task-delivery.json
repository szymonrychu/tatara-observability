  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Every live Task, the stage it is in, and how long it has been sitting there (worst first). Replaces the old Open Issues table, which read tatara_issue_state - the per-issue gauge of the issueLifecycle machine, which the task-centric redesign deletes (contract L.1). CONTRACT GAP: K.1 labels operator_task_stage_age_seconds with {task,stage,kind} only - no project/repo/issue - so this board can no longer link a row to its SCM issue, nor filter by project. The Task name is the only handle it has.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "stage"},
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "approved": {"color": "green", "index": 5, "text": "approved"},
                      "brainstorming": {"color": "yellow", "index": 1, "text": "brainstorming"},
                      "clarifying": {"color": "yellow", "index": 2, "text": "clarifying"},
                      "delivered": {"color": "dark-green", "index": 10, "text": "delivered"},
                      "deploying": {"color": "dark-blue", "index": 9, "text": "deploying"},
                      "documenting": {"color": "blue", "index": 11, "text": "documenting"},
                      "failed": {"color": "red", "index": 13, "text": "failed"},
                      "implementing": {"color": "green", "index": 6, "text": "implementing"},
                      "investigating": {"color": "orange", "index": 3, "text": "investigating"},
                      "merging": {"color": "purple", "index": 8, "text": "merging"},
                      "parked": {"color": "red", "index": 14, "text": "parked"},
                      "refining": {"color": "yellow", "index": 4, "text": "refining"},
                      "rejected": {"color": "red", "index": 12, "text": "rejected"},
                      "reviewing": {"color": "cyan", "index": 7, "text": "reviewing"},
                      "triaging": {"color": "blue", "index": 0, "text": "triaging"}
                    },
                    "type": "value"
                  }
                ]
              },
              {"id": "custom.cellOptions", "value": {"type": "color-background"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "kind"},
            "properties": [{"id": "custom.width", "value": 130}]
          },
          {
            "matcher": {"id": "byName", "options": "task"},
            "properties": [{"id": "custom.width", "value": 320}]
          }
        ]
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "stage age"}]
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "max by (task, stage, kind) (operator_task_stage_age_seconds{stage=~\"$stage\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "title": "Open Tasks by Stage (age in stage, worst first)",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "__name__": true},
            "includeByName": {},
            "indexByName": {"Value": 3, "kind": 1, "stage": 2, "task": 0},
            "renameByName": {"Value": "stage age"}
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Per-issue turns and token usage for issues with any agent activity. Columns populate once the operator_task_turns_total metric is live. Sorted by turns descending to surface the most-active issues.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "issue"},
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "targetBlank": true,
                    "title": "GitHub",
                    "url": "https://github.com/szymonrychu/${__data.fields.repo}/issues/${__data.fields.number}"
                  },
                  {
                    "targetBlank": true,
                    "title": "GitLab",
                    "url": "https://gitlab.com/szymonrychu/${__data.fields.repo}/-/issues/${__data.fields.number}"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Tokens"},
            "properties": [
              {"id": "unit", "value": "short"},
              {"id": "custom.width", "value": 90},
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "yellow", "value": 50000},
                    {"color": "red", "value": 200000}
                  ]
                }
              },
              {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Turns"},
            "properties": [
              {"id": "unit", "value": "short"},
              {"id": "custom.width", "value": 70},
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "yellow", "value": 10},
                    {"color": "red", "value": 30}
                  ]
                }
              },
              {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 10},
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": ["Tokens", "Turns"],
          "reducer": ["sum"],
          "show": true
        },
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "Turns"}]
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "sum by(project, repo, issue, kind) (operator_task_tokens_total{project=~\"$project\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "sum by(project, repo, issue, kind) (operator_task_turns_total{project=~\"$project\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "B"
        }
      ],
      "title": "Per-Issue Agent Progress (Turns and Tokens)",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "extractFields",
          "options": {
            "format": "regex",
            "regExp": "[#!](?<number>\\d+)$",
            "source": "issue",
            "replace": false
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "number": true
            },
            "includeByName": {},
            "indexByName": {
              "issue": 2,
              "kind": 3,
              "project": 0,
              "repo": 1
            },
            "renameByName": {
              "Value #A": "Tokens",
              "Value #B": "Turns",
              "Value (A)": "Tokens",
              "Value (B)": "Turns",
              "A": "Tokens",
              "B": "Turns"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Active (non-terminal, non-delivered) Tasks by origin kind, against the number of agent pods actually running. Replaces the old in-flight-Task gauge (tatara_tasks_inflight), which the redesign deletes: a Task is now long-lived and a running pod is the scarce resource, so a Task count and a pod count are different questions (contract K.2 says exactly this - re-express against operator_task_stage and the agent-pod count, never the Task count). Tasks well above pods means work is queued or parked, not running.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "normal"},
            "thresholdsStyle": {"mode": "off"}
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 18},
      "id": 3,
      "options": {
        "legend": {
          "calcs": ["lastNotNull"],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "sum by(kind) (operator_task_stage{stage!~\"delivered|rejected|failed|parked\"})",
          "legendFormat": "{{kind}} (tasks)",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "sum(kube_pod_container_status_running{namespace=\"tatara\",container=\"wrapper\"}) or vector(0)",
          "legendFormat": "agent pods running",
          "refId": "B"
        }
      ],
      "title": "Active Work by Kind, and Running Agent Pods",
      "type": "timeseries"
    },
