  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "All open issues tracked by the tatara operator. project=tatara -> GitHub; project=infrastructure -> GitLab. Click an issue number for the per-platform link.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "issue"},
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "targetBlank": true,
                    "title": "GitHub",
                    "url": "https://github.com/szymonrychu/${__data.fields.repo}/issues/${__data.fields.number}"
                  },
                  {
                    "targetBlank": true,
                    "title": "GitLab",
                    "url": "https://gitlab.com/szymonrychu/${__data.fields.repo}/-/issues/${__data.fields.number}"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "incident"},
            "properties": [
              {
                "id": "custom.width",
                "value": 90
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "false": {"color": "blue", "index": 0, "text": "no"},
                      "true": {"color": "red", "index": 1, "text": "INCIDENT"}
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {"type": "color-background"}
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "state"},
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "awaiting-approval": {"color": "orange", "index": 1, "text": "awaiting-approval"},
                      "implementing": {"color": "green", "index": 2, "text": "implementing"},
                      "main-ci": {"color": "dark-blue", "index": 5, "text": "main-ci"},
                      "merging": {"color": "purple", "index": 4, "text": "merging"},
                      "mr-ci": {"color": "blue", "index": 3, "text": "mr-ci"},
                      "reviewing": {"color": "cyan", "index": 6, "text": "reviewing"},
                      "triage": {"color": "yellow", "index": 0, "text": "triage"}
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {"type": "color-background"}
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "kind"},
            "properties": [
              {"id": "custom.width", "value": 130}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "project"},
            "properties": [
              {"id": "custom.width", "value": 110}
            ]
          }
        ]
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true,
        "sortBy": [{"desc": false, "displayName": "state"}]
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "tatara_issue_state{project=~\"$project\", state=~\"$state\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "title": "Open Issues",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "format": "regex",
            "regExp": "[#!](?<number>\\d+)$",
            "source": "issue",
            "replace": false
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "number": true
            },
            "includeByName": {},
            "indexByName": {
              "incident": 5,
              "issue": 2,
              "kind": 3,
              "project": 0,
              "repo": 1,
              "state": 4
            },
            "renameByName": {}
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Per-issue turns and token usage for issues with any agent activity. Columns populate once the operator_task_turns_total metric is live. Sorted by turns descending to surface the most-active issues.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "issue"},
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "targetBlank": true,
                    "title": "GitHub",
                    "url": "https://github.com/szymonrychu/${__data.fields.repo}/issues/${__data.fields.number}"
                  },
                  {
                    "targetBlank": true,
                    "title": "GitLab",
                    "url": "https://gitlab.com/szymonrychu/${__data.fields.repo}/-/issues/${__data.fields.number}"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Tokens"},
            "properties": [
              {"id": "unit", "value": "short"},
              {"id": "custom.width", "value": 90},
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "yellow", "value": 50000},
                    {"color": "red", "value": 200000}
                  ]
                }
              },
              {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Turns"},
            "properties": [
              {"id": "unit", "value": "short"},
              {"id": "custom.width", "value": 70},
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "yellow", "value": 10},
                    {"color": "red", "value": 30}
                  ]
                }
              },
              {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 10},
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": ["Tokens", "Turns"],
          "reducer": ["sum"],
          "show": true
        },
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "Turns"}]
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "sum by(project, repo, issue, kind) (operator_task_tokens_total{project=~\"$project\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "editorMode": "code",
          "expr": "sum by(project, repo, issue, kind) (operator_task_turns_total{project=~\"$project\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "B"
        }
      ],
      "title": "Per-Issue Agent Progress (Turns and Tokens)",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "extractFields",
          "options": {
            "format": "regex",
            "regExp": "[#!](?<number>\\d+)$",
            "source": "issue",
            "replace": false
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "number": true
            },
            "includeByName": {},
            "indexByName": {
              "issue": 2,
              "kind": 3,
              "project": 0,
              "repo": 1
            },
            "renameByName": {
              "Value #A": "Tokens",
              "Value #B": "Turns",
              "Value (A)": "Tokens",
              "Value (B)": "Turns",
              "A": "Tokens",
              "B": "Turns"
            }
          }
        }
      ],
      "type": "table"
    },
