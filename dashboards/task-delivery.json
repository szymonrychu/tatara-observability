      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": ["USD"], "reducer": ["sum"], "show": true},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "USD"}]
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
